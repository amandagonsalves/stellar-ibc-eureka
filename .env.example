# Stellar network + deployer key — signs/deploys the soroban contracts
STELLAR_CHAIN_ID=stellar-testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_SIGNING_KEY=
STELLAR_KEY_NAME=stellar-relayer
DEPLOYER_IDENTITY=admin
DEPLOYER_ADDRESS=

# Stellar sender/receiver accounts — endpoints of an ICS-20 transfer
STELLAR_SENDER_IDENTITY=stellar-sender
STELLAR_SENDER_ADDRESS=
STELLAR_SENDER_KEY=
STELLAR_RECEIVER_IDENTITY=stellar-receiver
STELLAR_RECEIVER_ADDRESS=
STELLAR_RECEIVER_KEY=

# Stellar api service — where it binds and the URL the CLI probes
STELLAR_API_HOST=0.0.0.0
STELLAR_API_PORT=8101
STELLAR_API_URL=http://127.0.0.1:8101

# Stellar gateway gRPC service — where it binds and the URL the CLI queries
STELLAR_GATEWAY_HOST=0.0.0.0
STELLAR_GATEWAY_GRPC_PORT=50052
STELLAR_GATEWAY_URL=127.0.0.1:50052

# Local Cosmos devnet (simd-1) — endpoints, relayer/validator keys, accounts
COSMOS_CHAIN_ID=simd-1
COSMOS_RPC_URL=http://127.0.0.1:26657
COSMOS_REST_URL=http://127.0.0.1:1317
COSMOS_GRPC_URL=http://127.0.0.1:9090
COSMOS_KEY_NAME=relayer
COSMOS_ACCOUNT_PREFIX=cosmos
COSMOS_GAS_DENOM=stake
COSMOS_VALIDATOR_MNEMONIC=
COSMOS_RELAYER_MNEMONIC=
COSMOS_PROPOSER_PRIVATE_KEY=
COSMOS_FUNDER_PRIVATE_KEY=
COSMOS_SENDER_KEY_NAME=cosmos-sender
COSMOS_SENDER_ADDRESS=
COSMOS_RECEIVER_KEY_NAME=cosmos-receiver
COSMOS_RECEIVER_ADDRESS=

# Cosmos testnet (provider) — used when targeting the public chain instead of the devnet
COSMOS_TESTNET_NAME=cosmos-testnet
COSMOS_TESTNET_CHAIN_ID=provider
COSMOS_TESTNET_RPC_URL=https://rpc.provider-sentry-01.hub-testnet.polypore.xyz
COSMOS_TESTNET_REST_URL=https://rest.provider-sentry-01.hub-testnet.polypore.xyz
COSMOS_TESTNET_GRPC_URL=https://grpc.provider-sentry-01.hub-testnet.polypore.xyz
COSMOS_TESTNET_FAUCET_URL=https://faucet.polypore.xyz
COSMOS_TESTNET_MNEMONIC=
COSMOS_TESTNET_KEY_NAME=interstellar-cosmos
COSMOS_TESTNET_KEYRING_BACKEND=test

# Deployed Soroban contract addresses — written by `tx contracts deploy`
ROUTER_CONTRACT_ADDRESS=
TRANSFER_CONTRACT_ADDRESS=
MOCK_LC_CONTRACT_ID=
ATTESTATION_LC_CONTRACT_ID=
TENDERMINT_LC_CONTRACT_ID=

# api container image — pulled/run by docker compose
API_IMAGE=amandagonsalvesx/stellar-eureka-api
API_TAG=latest
API_REGISTRY=

# gateway container image — pulled/run by docker compose
GATEWAY_IMAGE=amandagonsalvesx/stellar-eureka-gateway
GATEWAY_TAG=latest
GATEWAY_REGISTRY=

# hermes relayer image + source repo (for `services build --hermes`) + config
HERMES_IMAGE=amandagonsalvesx/stellar-hermes-cardano
HERMES_TAG=latest
HERMES_REGISTRY=
HERMES_REPO_URL=
HERMES_BRANCH=main
HERMES_CONFIG_PATH=/home/hermes/.hermes/config.toml
HERMES_LOG_LEVEL=debug

# Docker registry credentials — pull/push the private images
DOCKER_USERNAME=
DOCKER_TOKEN=
